# Copy to .env for local development only.
# Do not put real secrets, tokens, device addresses, or private subject data here.

MUSE_TMR_DATA_DIR=data
MUSE_TMR_RECORDINGS_DIR=data/recordings
MUSE_TMR_REPORTS_DIR=data/reports
MUSE_TMR_AUDIO_DIR=audio/private
MUSE_TMR_LOG_LEVEL=INFO

# Optional local-only paths. These must not be committed.
MUSE_SDK_PATH=
OPENMUSE_LSL_ENABLED=false
